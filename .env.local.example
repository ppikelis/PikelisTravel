# Sanity project — get these from https://www.sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=y3gc8dx6
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: pin the API date. Defaults to today's date in sanity/env.js if unset.
# NEXT_PUBLIC_SANITY_API_VERSION=2026-04-24

# Server-only token for write operations (import script, webhooks). Generate at
# https://www.sanity.io/manage/project/y3gc8dx6/api and paste below. Do NOT commit.
# SANITY_API_WRITE_TOKEN=

# Webhook secret used by Sanity → Vercel on-demand revalidation.
# Set this to any long random string, then configure the same value in the
# Sanity webhook header (x-sanity-revalidate-secret). See /api/revalidate.
# SANITY_REVALIDATE_SECRET=

# ─── Beehiiv (newsletter) ──────────────────────────────────────────────────
# Workspace API key. Beehiiv dashboard → Settings → API → create new key.
# BEEHIIV_API_KEY=

# Publication ID (V2, starts with pub_). Beehiiv dashboard → Settings → API.
# BEEHIIV_PUBLICATION_ID=

# ─── PostHog (analytics) ───────────────────────────────────────────────────
# Project API key from https://eu.posthog.com → project settings (starts with phc_).
# Use the EU host for GDPR-friendly data residency.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─── Polar (payments) ──────────────────────────────────────────────────────
# Runtime token used by /api/checkout. Org token, scopes: checkouts:write,
# checkouts:read, products:read. Polar dashboard → Settings → Developer.
# POLAR_ACCESS_TOKEN=

# Webhook signing secret. Polar dashboard → Settings → Webhooks → endpoint.
# POLAR_WEBHOOK_SECRET=

# Separate token for the sync script (npm run sync:polar). Scopes:
# products:write, benefits:write, files:write, organizations:read.
# Keep this OUT of Vercel — script-only, lives in .env.local.
# POLAR_SYNC_TOKEN=

# Required to be "1" before sync:polar performs any writes (safety flag).
# POLAR_SYNC_ENABLED=

# "sandbox" while testing, "production" when going live. Used by both the
# checkout adapter and the sync script.
# POLAR_SERVER=sandbox

# Used to build the Polar checkout successUrl. No trailing slash.
# NEXT_PUBLIC_SITE_URL=https://testedroutes.com

# ─── Anthropic (Claude metadata generation) ───────────────────────────────
# API key for `npm run publish -- <folder> --generate-metadata`.
# Get a key at https://console.anthropic.com/settings/keys.
# ANTHROPIC_API_KEY=

# Optional: override the Claude model used for metadata generation.
# Defaults to claude-sonnet-4-6 (good balance of quality + cost).
# CLAUDE_MODEL=claude-sonnet-4-6

# ─── Affiliate tracking IDs ───────────────────────────────────────────────
# Each var holds the tracking ID for one direct affiliate program that
# accepts a simple URL parameter (Booking aid=, Amazon tag=, etc.). The
# /go/<slug> redirector (app/go/[slug]/route.js) appends the right
# param at click time, with country-aware Amazon storefront swap.
#
# Meta-platform programs (Awin, Impact, CJ, AvantLink) don't appear
# below — their tracking is baked into the deeplink URL the platform
# generates, which the editor pastes into affiliates.yaml directly.
#
# Leave any var unset and the corresponding links render untagged
# (link works, no commission, no breakage). Rotate these on Vercel to
# migrate accounts (e.g. personal-Swiss → LT MB) without touching
# guide content.
#
# Booking.com Partner Programme. Numeric "aid" from your partner dashboard.
# BOOKING_AID=
#
# Agoda Partners. "cid" from the Agoda partner dashboard.
# AGODA_CID=
#
# GetYourGuide partner ID. Partner portal → "Tracking".
# GYG_PARTNER_ID=
#
# Kiwi.com affiliate ID. Partner panel → "API & integrations".
# KIWI_AFFILID=
#
# Amazon Associates tags. Region-aware: the redirector reads
# x-vercel-ip-country and picks the right host + tag at click time.
# Sign-up for .com first; add UK / DE when LT MB lands and you apply
# to those Associates regions.
# AMAZON_TAG_US=
# AMAZON_TAG_UK=
# AMAZON_TAG_DE=
#
# SafetyWing referenceID. Kept for backwards compat — not part of v1
# strategy (deferred per project_affiliate_strategy memory).
# SAFETYWING_REF=
