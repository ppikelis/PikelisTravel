# Sanity project — get these from https://www.sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=y3gc8dx6
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: pin the API date. Defaults to today's date in sanity/env.js if unset.
# NEXT_PUBLIC_SANITY_API_VERSION=2026-04-24

# Server-only token for write operations (import script, webhooks). Generate at
# https://www.sanity.io/manage/project/y3gc8dx6/api and paste below. Do NOT commit.
# SANITY_API_WRITE_TOKEN=

# Webhook secret used by Sanity → Vercel on-demand revalidation.
# Set this to any long random string, then configure the same value in the
# Sanity webhook header (x-sanity-revalidate-secret). See /api/revalidate.
# SANITY_REVALIDATE_SECRET=

# ─── Polar (payments) ──────────────────────────────────────────────────────
# Organization access token. Polar dashboard → Settings → Developer → tokens.
# POLAR_ACCESS_TOKEN=

# Webhook signing secret. Polar dashboard → Settings → Webhooks → endpoint.
# POLAR_WEBHOOK_SECRET=

# "sandbox" while testing, "production" when going live.
# POLAR_SERVER=sandbox

# Used to build the Polar checkout successUrl. No trailing slash.
# NEXT_PUBLIC_SITE_URL=https://pikelistravel.com
